+
+        loop {
+            let flags = {
+                let ports = self
+                    .hci
+                    .ports
+                    .lock()
+                    .unwrap_or_else(|poisoned| poisoned.into_inner());
+                ports[port_array_index].flags()
+            };
+
+            if Self::port_is_enabled(&flags)
+                || !flags.contains(PortFlags::PR)
+                || start.elapsed() >= settle_timeout
+            {
