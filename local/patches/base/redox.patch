+            None | Some("") => Ok(HandleKind::PowerAdapterDir(adapter.id.clone())),
+            Some(name) => Ok(HandleKind::PowerFile(
+                power_adapter_file_contents(adapter, name).ok_or(Error::new(ENOENT))?,
+            )),
