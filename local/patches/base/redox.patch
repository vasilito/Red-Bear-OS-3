+        args: &[u64],
+    ) -> Result<Vec<u64>, AmlEvalError> {
+        let full_path = format!("{path}.{method}");
+        let aml_name =
+            AmlName::from_str(&full_path).map_err(|_| AmlEvalError::DeserializationError)?;
