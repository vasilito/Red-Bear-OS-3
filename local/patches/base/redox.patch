+    ) -> io::Result<DeviceConsumerHandleEvent<'a>> {
+        match read_to_slice(self.0.as_fd(), events) {
+            Ok(count) => Ok(DeviceConsumerHandleEvent::Events(&events[..count])),
+            Err(err) => Err(err.into()),
+        }
+    }
+}
