+pub struct NamedProducerHandle(File);
+
+impl NamedProducerHandle {
+    pub fn new(name: &str) -> io::Result<Self> {
+        let path = format!("/scheme/input/producer/{name}");
+        Ok(Self(File::open(path)?))
