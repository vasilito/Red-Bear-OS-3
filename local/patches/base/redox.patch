+    fn power_adapter_handle(&self, path: &str) -> Result<HandleKind<'acpi>> {
+        let normalized = path.trim_matches('/');
+        if normalized.is_empty() {
+            return Ok(HandleKind::PowerAdaptersDir);
+        }
+
