+                    }
+                },
+                Ok(value) => {
+                    log::warn!("\\_S5 returned unexpected AML value: {:?}", value);
+                    None
+                }
+                Err(error) => {
+                    log::warn!("Failed to evaluate \\_S5: {:?}", error);
+                    None
+                }
+            },
+            Err(error) => {
