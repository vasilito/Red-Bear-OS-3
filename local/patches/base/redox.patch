+        let rollback_input_context_physical = match self.restore_configure_input_context(
+            port,
+            configure_snapshot,
+            endpoint_snapshots,
+        ) {
+            Ok(physical) => physical,
+            Err(restore_err) => {
+                warn!(
+                    "failed to restore configure input context after {}: {:?}",
