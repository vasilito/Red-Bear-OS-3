+pub enum DeviceConsumerHandleEvent<'a> {
+    Events(&'a [Event]),
+}
+
+impl DeviceConsumerHandle {
+    pub fn new(device_name: &str) -> io::Result<Self> {
+        let path = format!("/scheme/input/{device_name}");
+        Ok(Self(File::open(path)?))
+    }
