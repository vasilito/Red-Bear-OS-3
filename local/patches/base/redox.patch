+    fn restore_configure_input_context(
+        &self,
+        port: PortId,
+        snapshot: ConfigureContextSnapshot,
+        endpoint_snapshots: &[(usize, EndpointContextSnapshot)],
+    ) -> Result<usize> {
+        let port_state = self.port_states.get(&port).ok_or(Error::new(EBADFD))?;
