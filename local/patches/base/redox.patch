+        let normalized = path.trim_matches('/');
+
+        if normalized.is_empty() {
+            return Ok(HandleKind::PowerDir);
+        }
+        if normalized == "on_battery" {
+            return Ok(HandleKind::PowerFile(power_bool_contents(
+                self.power_snapshot()?.on_battery(),
+            )));
+        }
