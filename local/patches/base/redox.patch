+            return Err(Error::new(ENODEV));
+        };
+
+        let caps = self.get_capabilities(dac)?;
+        let max_channels = ((caps >> 0) & 0xFF) as u8 + 1;
+        let channels = if max_channels >= 2 { 2 } else { max_channels };
