+            product_name: Some("Laptop 16".to_string()),
+            ..DmiInfo::default()
+        };
+
+        let rendered = info.to_match_lines();
+        assert_eq!(
+            rendered,
+            "sys_vendor=Framework\nboard_name=FRANMECP01\nproduct_name=Laptop 16"
+        );
+    }
