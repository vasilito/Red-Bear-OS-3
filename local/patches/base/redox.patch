+        assert_eq!(
+            resource_symbol_path("_SB.PCI0.I2C0.TPD0").as_deref(),
+            Some("_SB.PCI0.I2C0.TPD0._CRS")
+        );
+        assert_eq!(
+            resource_symbol_path("\\_SB/PCI0/I2C0/TPD0").as_deref(),
+            Some("_SB.PCI0.I2C0.TPD0._CRS")
+        );
+    }
+
