+
+    #[test]
+    fn try_validate_accepts_in_range_table_and_pba() {
+        let info = MsixInfo {
+            table_bar: 0,
+            table_offset: 0x100,
+            table_size: 4,
+            pba_bar: 1,
+            pba_offset: 0x80,
+        };
+        let mut bars = [PciBar::None; 6];
+        bars[0] = PciBar::Memory32 {
+            addr: 0x1000,
+            size: 0x400,
+        };
+        bars[1] = PciBar::Memory32 {
+            addr: 0x2000,
+            size: 0x200,
+        };
+
+        assert!(info.try_validate(bars).is_ok());
+    }
+
+    #[test]
+    fn try_validate_rejects_reserved_bir() {
+        let info = MsixInfo {
+            table_bar: 6,
+            table_offset: 0,
