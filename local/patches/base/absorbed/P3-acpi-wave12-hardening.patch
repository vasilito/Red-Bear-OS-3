+    if candidate.len() < 36 {
+        return false;
+    }
+
+    let declared_length = u32::from_le_bytes([candidate[20], candidate[21], candidate[22], candidate[23]])
+        as usize;
+    if declared_length < 36 || candidate.len() < declared_length {
+        return false;
+    }
+
+    checksum_is_zero(&candidate[..declared_length]).is_ok()
+}
