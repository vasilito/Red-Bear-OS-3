+#[cfg(any(target_arch = "x86", target_arch = "x86_64"))]
+fn checksum_is_zero(bytes: &[u8]) -> Result<(), ()> {
+    let checksum = bytes
+        .iter()
+        .copied()
+        .fold(0_u8, |current_sum, item| current_sum.wrapping_add(item));
