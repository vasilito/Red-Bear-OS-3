+
+impl PortLinkState {
+    const PORT_STATE_MASK: u32 = 0b1111 << 5;
+
+    pub fn from_port_state(state: u8) -> Option<Self> {
+        match state {
+            0 => Some(Self::U0),
+            1 => Some(Self::U1),
+            2 => Some(Self::U2),
+            3 => Some(Self::U3),
+            _ => None,
+        }
+    }
+
+    pub fn as_str(self) -> &'static str {
+        match self {
+            Self::U0 => "U0",
+            Self::U1 => "U1",
+            Self::U2 => "U2",
+            Self::U3 => "U3",
+        }
+    }
