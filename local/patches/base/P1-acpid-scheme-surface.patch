+const DMI_DIRECTORY_ENTRIES: &[&str] = &[
+    "sys_vendor",
+    "board_vendor",
+    "board_name",
+    "board_version",
+    "product_name",
+    "product_version",
+    "bios_version",
+    "match_all",
+];
