+fn sanitize_power_id(path: &str) -> String {
+    let sanitized = path
+        .chars()
+        .map(|ch| if ch.is_ascii_alphanumeric() { ch } else { '_' })
+        .collect::<String>()
+        .trim_matches('_')
+        .to_string();
+
+    if sanitized.is_empty() {
+        String::from("device")
+    } else {
+        sanitized
+    }
+}
