+                    return Err(Error::new(EINVAL));
+                }
+                self.ctx.acpi_reboot().map_err(|error| {
+                    log::error!("ACPI reboot failed: {error}");
+                    Error::new(EIO)
+                })?;
+                Ok(buf.len())
+            }
+            _ => Err(Error::new(EBADF)),
+        }
+    }
