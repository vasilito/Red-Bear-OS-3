+        buf[4..8].copy_from_slice(&self.device_id.to_ne_bytes());
+        buf[8..12].copy_from_slice(&self.name_len.to_ne_bytes());
+        buf[12..16].copy_from_slice(&self._reserved.to_ne_bytes());
+        buf
+    }
+}
