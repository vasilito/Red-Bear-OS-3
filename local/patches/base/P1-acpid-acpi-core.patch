+                }
+            }
+        }
+
+        for path in battery_paths {
+            let mut battery = AcpiBattery {
+                id: symbol_leaf_id(&path),
+                path: path.clone(),
+                ..AcpiBattery::default()
+            };
+
+            match self.aml_eval(
+                AmlName::from_str(&format!("\\{}.{}", path, "_BST"))
+                    .map_err(|_| AmlEvalError::DeserializationError)?,
