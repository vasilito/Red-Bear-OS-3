-
-    libredox::call::setrens(0, 0).expect("rtl8139d: failed to enter null namespace");
-
-    scheme.tick().unwrap();
+        .unwrap_or_else(|err| {
+            log::error!("rtl8139d: failed to subscribe to scheme fd: {err}");
