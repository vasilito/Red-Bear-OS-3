+    pub fn read_block(&mut self, buf: &mut [u8]) -> Result<usize> {
+        let len = min(self.block_size(), buf.len());
+        unsafe {
+            copy_nonoverlapping(
+                (self.addr() + self.current_block() * self.block_size()) as *const u8,
+                buf.as_mut_ptr(),
+                len,
+            );
+        }
+        self.cur_pos += 1;
+        self.cur_pos %= self.block_count();
+        Ok(len)
+    }
