diff --git a/zerod/src/main.rs b/zerod/src/main.rs
index c9bd1465..59f6b97c 100644
--- a/zerod/src/main.rs
+++ b/zerod/src/main.rs
@@ -5,6 +5,7 @@ use scheme_utils::Blocking;
 
 mod scheme;
 
+#[derive(Clone, Copy)]
 enum Ty {
     Null,
     Zero,
@@ -15,21 +16,36 @@ fn main() {
 }
 
 fn daemon(daemon: daemon::SchemeDaemon) -> ! {
