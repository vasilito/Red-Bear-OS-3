+    c: u32,
+}
+
+impl EndpointContextSnapshot {
+    fn capture_values(a: u32, b: u32, trl: u32, trh: u32, c: u32) -> Self {
+        Self { a, b, trl, trh, c }
+    }
+
+    fn restore<const N: usize>(&self, ctx: &mut EndpointContext<N>) {
+        ctx.a.write(self.a);
+        ctx.b.write(self.b);
+        ctx.trl.write(self.trl);
+        ctx.trh.write(self.trh);
+        ctx.c.write(self.c);
+    }
+}
