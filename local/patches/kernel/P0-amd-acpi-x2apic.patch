     };
     result.flush();
 
     // Write trampoline, make sure TRAMPOLINE page is free for use
     for (i, val) in TRAMPOLINE_DATA.iter().enumerate() {
         unsafe {
             (*((TRAMPOLINE as *mut u8).add(i) as *const AtomicU8)).store(*val, Ordering::SeqCst);
         }
