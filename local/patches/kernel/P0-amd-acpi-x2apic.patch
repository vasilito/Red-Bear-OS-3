                     core::arch::asm!("");
                 };
                 AP_READY.store(false, Ordering::SeqCst);
 
                 // Send INIT IPI
                 {
                     let mut icr = 0x4500;
                     if local_apic.x2 {
                         icr |= u64::from(ap_local_apic.id) << 32;
                     } else {
                         icr |= u64::from(ap_local_apic.id) << 56;
                     }
                     local_apic.set_icr(icr);
                 }
 
                 // Send START IPI
                 {
                     let ap_segment = (TRAMPOLINE >> 12) & 0xFF;
                     let mut icr = 0x4600 | ap_segment as u64;
 
                     if local_apic.x2 {
