                     }
 
                     local_apic.set_icr(icr);
                 }
 
                 // Wait for trampoline ready
                 while unsafe { (*ap_ready.cast::<AtomicU8>()).load(Ordering::SeqCst) } == 0 {
                     hint::spin_loop();
                 }
                 while !AP_READY.load(Ordering::SeqCst) {
                     hint::spin_loop();
                 }
 
