+	$(warning !! The repo binary still protects local overlays unless REDBEAR_ALLOW_LOCAL_UNFETCH=1)
+	$(MAKE) fetch_clean REDBEAR_ALLOW_LOCAL_UNFETCH=1
+	$(MAKE) clean NOT_ON_PODMAN=1
+endif # PODMAN_BUILD
