+wait_for_wayland_socket() {
+    socket_path="$XDG_RUNTIME_DIR/$WAYLAND_DISPLAY"
+    attempts=0
+    while [ "$attempts" -lt 30 ]; do
+        if [ -e "$socket_path" ]; then
+            return 0
+        fi
+        if ! kill -0 "$kwin_pid" 2>/scheme/null; then
+            return 1
+        fi
+        attempts=$((attempts + 1))
