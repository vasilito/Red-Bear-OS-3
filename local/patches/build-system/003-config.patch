+description = "USB-C UCSI topology detector (non-blocking on live-mini)"
+requires_weak = [
+    "00_base.target",
+    "00_i2cd.service",
+]
+
+[service]
+cmd = "ucsid"
+type = "oneshot_async"
+"""
