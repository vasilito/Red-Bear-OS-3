+[service]
+cmd = "redbear-wifictl"
+type = { scheme = "wifictl" }
+"""
+
+[[files]]
+path = "/usr/lib/init.d/12_dbus.service"
+data = """
+[unit]
+description = "D-Bus system bus"
+requires_weak = [
+    "12_boot-late.target",
