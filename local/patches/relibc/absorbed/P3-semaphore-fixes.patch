 pub unsafe extern "C" fn sem_close(sem: *mut sem_t) -> c_int {
-    todo!("named semaphores")
+    if sem.is_null() || sem == SEM_FAILED_PTR {
+        ERRNO.set(EINVAL);
+        return -1;
+    }
+
+    unsafe { munmap(sem.cast::<c_void>(), mem::size_of::<NamedSemaphore>()) }
 }
 
