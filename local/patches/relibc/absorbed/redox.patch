+            LIO_READ => {
+                if unsafe { aio_read(cb) } != 0 {
+                    any_failed = true;
+                }
+            }
+            LIO_WRITE => {
+                if unsafe { aio_write(cb) } != 0 {
+                    any_failed = true;
+                }
+            }
+            LIO_NOP => {}
+            _ => {
+                cb.__state = _AIO_DONE;
+                cb.__error_code = EINVAL;
+                cb.__return_value = -1;
