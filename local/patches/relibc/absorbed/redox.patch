+#[unsafe(no_mangle)]
+pub unsafe extern "C" fn aio_cancel(fildes: c_int, aiocbp: *mut aiocb) -> c_int {
+    if !aiocbp.is_null() {
+        let cb = unsafe { &*aiocbp };
