--- a/src/platform/redox/exec.rs
+++ b/src/platform/redox/exec.rs
@@ -129,16 +129,19 @@ pub fn execve(
 
     let Resugid { ruid, rgid, .. } = redox_rt::sys::posix_getresugid();
 
-    let mode = if ruid == stat.st_uid {
-        (stat.st_mode >> 3 * 2) & 0o7
