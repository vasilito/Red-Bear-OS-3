+    // Root (uid 0) bypasses execute permission checks, matching Linux behavior.
+    if ruid != 0 {
+        let mode = if ruid == stat.st_uid {
+            (stat.st_mode >> 3 * 2) & 0o7
+        } else if rgid == stat.st_gid {
+            (stat.st_mode >> 3 * 1) & 0o7
+        } else {
+            stat.st_mode & 0o7
+        };
 
-    if mode & 0o1 == 0o0 {
